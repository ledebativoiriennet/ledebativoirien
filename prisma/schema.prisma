generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                String             @id @default(cuid())
  name              String?
  email             String?            @unique
  password          String?
  role              String             @default("USER")
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  companyId         String?
  lastLoginAt       DateTime?
  articleLikes      ArticleLike[]
  purchases         Purchase[]
  pushSubscriptions PushSubscription[]
  readingHistory    ReadingHistory[]
  subscriptions     Subscription[]
  comments          Comment[]
  company           Company?           @relation(fields: [companyId], references: [id])
}

model Subscription {
  id        String    @id @default(cuid())
  userId    String
  plan      String    @default("PREMIUM")
  status    String    @default("ACTIVE")
  startDate DateTime  @default(now())
  endDate   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id])
}

model Author {
  id          String             @id @default(cuid())
  wpId        Int?               @unique
  name        String
  slug        String             @unique
  email       String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  articles    Article[]
  subscribers AuthorSubscriber[]
}

model Category {
  id        String     @id @default(cuid())
  wpId      Int?       @unique
  name      String
  slug      String     @unique
  parentId  String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  parent    Category?  @relation("CategoryToCategory", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryToCategory")
  articles  Article[]  @relation("ArticleToCategory")
}

model Article {
  id               String           @id @default(cuid())
  wpId             Int?             @unique
  title            String
  slug             String           @unique
  content          String
  excerpt          String?
  imageUrl         String?
  imageCaption     String?
  isPremium        Boolean          @default(false)
  isConfidentiel   Boolean          @default(false)
  isFeatured       Boolean          @default(false)
  publishedAt      DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  authorId         String?
  videoUrl         String?
  videoFile        String?
  videoCaption     String?
  seoTitle         String?
  seoDescription   String?
  isAudioAvailable Boolean          @default(false)
  author           Author?          @relation(fields: [authorId], references: [id])
  likes            ArticleLike[]
  views            ArticleView[]
  readingHistory   ReadingHistory[]
  categories       Category[]       @relation("ArticleToCategory")
  tags             Tag[]            @relation("ArticleToTag")
  comments         Comment[]
  relatedArticles  Article[]        @relation("RelatedArticles")
  referencedIn     Article[]        @relation("RelatedArticles")
}

model Poll {
  id        String       @id @default(cuid())
  question  String
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())
  options   PollOption[]
}

model PollOption {
  id     String @id @default(cuid())
  pollId String
  text   String
  votes  Int    @default(0)
  poll   Poll   @relation(fields: [pollId], references: [id], onDelete: Cascade)
}

model Obituary {
  id        String   @id @default(cuid())
  name      String
  details   String
  imageUrl  String?
  createdAt DateTime @default(now())
}

model PressRelease {
  id        String   @id @default(cuid())
  title     String
  company   String
  createdAt DateTime @default(now())
  url       String?
}

model Video {
  id        String   @id @default(cuid())
  title     String
  youtubeId String
  createdAt DateTime @default(now())
}

model MarketIndicator {
  id        String          @id @default(cuid())
  group     String
  label     String
  value     String
  trend     String
  extraText String?
  dateLabel String
  order     Int             @default(0)
  updatedAt DateTime        @updatedAt
  history   MarketHistory[]
}

model MarketHistory {
  id          String          @id @default(cuid())
  indicatorId String
  value       Float
  date        DateTime        @default(now())
  indicator   MarketIndicator @relation(fields: [indicatorId], references: [id], onDelete: Cascade)

  @@index([indicatorId, date])
}

model EconomicalIndicator {
  id        String   @id @default(cuid())
  country   String
  category  String
  value     String
  unit      String?
  year      Int
  trend     String?
  source    String?
  updatedAt DateTime @updatedAt
}

model Activity {
  id        String   @id @default(cuid())
  title     String
  date      String
  location  String
  imageUrl  String?
  link      String?
  createdAt DateTime @default(now())
}

model Tag {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  articles  Article[] @relation("ArticleToTag")
}

model FlashNews {
  id        String   @id @default(cuid())
  time      String
  content   String
  link      String?
  source    String?
  createdAt DateTime @default(now())
}

model JobOffer {
  id          String   @id @default(cuid())
  title       String
  company     String?
  location    String?
  description String?
  url         String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Visitor {
  id          String   @id @default(cuid())
  ipHash      String
  country     String?
  city        String?
  browser     String?
  os          String?
  device      String?
  brand       String?
  isBot       Boolean  @default(false)
  botName     String?
  botCategory String?
  path        String?
  source      String?
  referrer    String?
  visitedAt   DateTime @default(now())

  @@index([ipHash])
  @@index([isBot])
  @@index([source])
}

model Advertisement {
  id          String     @id @default(cuid())
  title       String
  company     String
  imageUrl    String
  linkUrl     String?
  slot        String
  status      String     @default("PENDING")
  startDate   DateTime?
  endDate     DateTime?
  clicks      Int        @default(0)
  impressions Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  events      AdEvent[]
}

model AdEvent {
  id        String        @id @default(cuid())
  adId      String
  type      String        // "IMPRESSION" | "CLICK"
  path      String?
  ipHash    String?
  userAgent String?
  createdAt DateTime      @default(now())
  ad        Advertisement @relation(fields: [adId], references: [id], onDelete: Cascade)

  @@index([adId])
  @@index([type])
  @@index([createdAt])
}

model WeatherReport {
  id                  String   @id @default(cuid())
  city                String   @default("Abidjan")
  temperature         Int
  condition           String
  icon                String?
  date                DateTime @default(now())
  updatedAt           DateTime @updatedAt
  forecast1Day        String?
  forecast1Icon       String?
  forecast1Temp       Int?
  forecast2Day        String?
  forecast2Icon       String?
  forecast2Temp       Int?
  forecast3Day        String?
  forecast3Icon       String?
  forecast3Temp       Int?
  apparentTemperature Int?
}

model AdInquiry {
  id        String   @id @default(cuid())
  company   String
  name      String
  email     String
  phone     String?
  format    String?
  message   String?
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ReadingHistory {
  id        String   @id @default(cuid())
  userId    String
  articleId String
  readAt    DateTime @default(now())
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, articleId])
}

model ArticleLike {
  id        String   @id @default(cuid())
  userId    String
  articleId String
  createdAt DateTime @default(now())
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, articleId])
}

model FootballMatch {
  id        String   @id @default(cuid())
  team1     String
  team2     String
  team1Flag String?
  team2Flag String?
  matchDate DateTime
  phase     String?
  score     String?
  status    String   @default("UPCOMING")
  sport     String   @default("Football")
  sportIcon String?  @default("⚽")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BreakingNews {
  id        String   @id @default(cuid())
  content   String
  link      String?
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Caricature {
  id        String   @id @default(cuid())
  title     String
  imageUrl  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Titrologie {
  id            String   @id @default(cuid())
  newspaperName String
  imageUrl      String
  date          DateTime @default(now())
  createdAt     DateTime @default(now())
}

model SiteSettings {
  id                  String   @id @default("global")
  facebookUrl         String?
  updatedAt           DateTime @updatedAt
  instagramUrl        String?
  linkedinUrl         String?
  twitterUrl          String?
  youtubeUrl          String?
  facebookAccessToken String?
  facebookPageId      String?
  linkedinAccessToken String?
  linkedinUrn         String?
  twitterAccessSecret String?
  twitterAccessToken  String?
  twitterApiKey       String?
  twitterApiSecret    String?
  footerCode          String?
  headerCode          String?
}

model Quote {
  id        String   @id @default(cuid())
  text      String
  author    String
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model AuthorSubscriber {
  id        String   @id @default(cuid())
  email     String
  authorId  String
  createdAt DateTime @default(now())
  author    Author   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@unique([email, authorId])
}

model DigitalNewspaper {
  id            String     @id @default(cuid())
  title         String
  description   String?
  issueNumber   Int?
  price         Float
  coverImageUrl String?
  pdfUrl        String
  publishedAt   DateTime   @default(now())
  isActive      Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  purchases     Purchase[]
}

model Purchase {
  id                 String           @id @default(cuid())
  userId             String?
  customerEmail      String
  customerName       String?
  digitalNewspaperId String
  companyId          String?
  amount             Float
  status             String           @default("PENDING")
  paymentMethod      String?
  transactionId      String?          @unique
  downloadToken      String           @unique @default(cuid())
  downloadCount      Int              @default(0)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  company            Company?         @relation(fields: [companyId], references: [id])
  digitalNewspaper   DigitalNewspaper @relation(fields: [digitalNewspaperId], references: [id])
  user               User?            @relation(fields: [userId], references: [id])
}

model ArticleView {
  id        String   @id @default(cuid())
  articleId String
  viewedAt  DateTime @default(now())
  ipHash    String?
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId, viewedAt])
  @@index([ipHash])
}

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  userId    String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}

model Company {
  id        String     @id @default(cuid())
  name      String
  email     String     @unique
  logoUrl   String?
  plan      String     @default("B2B_STANDARD")
  maxUsers  Int        @default(10)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  purchases Purchase[]
  users     User[]
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  userName  String?
  userEmail String?
  action    String
  resource  String?
  details   String?
  ipAddress String?
  userAgent String?
  browser   String?
  device    String?
  os        String?
  city      String?
  country   String?
  createdAt DateTime @default(now())
}

model LiveStream {
  id        String   @id @default(cuid())
  title     String   @default("Direct LDI")
  url       String
  platform  String   @default("OTHER")
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  articleId String
  userId    String
  isActive  Boolean  @default(true) // For moderation if needed later
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([articleId])
  @@index([userId])
}

model SearchEvent {
  id              String    @id @default(cuid())
  query           String
  ipHash          String
  clickedPosition Int?      // Position de l'article cliqué (1, 2, 3...)
  createdAt       DateTime  @default(now())

  @@index([createdAt])
  @@index([query])
}

model GoogleSearchStat {
  id          String   @id @default(cuid())
  date        DateTime
  query       String
  clicks      Int
  impressions Int
  position    Float
  ctr         Float
  createdAt   DateTime @default(now())

  @@unique([date, query])
}
